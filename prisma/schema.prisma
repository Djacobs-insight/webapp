generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model User {
  id                   String                 @id @default(cuid()) @map("id")
  email                String?                @unique @map("email")
  emailVerified        DateTime?              @map("email_verified")
  name                 String?                @map("name")
  image                String?                @map("image")
  birthday             DateTime?              @map("birthday")
  gender               String?                @map("gender")
  parkrunHomeEvent     String?                @map("parkrun_home_event")
  onboardingCompleted  Boolean                @default(false) @map("onboarding_completed")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  deletedAt            DateTime?              @map("deleted_at")
  accounts             Account[]
  sessions             Session[]
  notificationPrefs    NotificationPreference?
  familyMemberships    FamilyMember[]
  sentInvites          Invite[]
  results              ParkrunResult[]
  milestones           Milestone[]
  photos               Photo[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid()) @map("id")
  userId            String  @map("user_id")
  type              String  @map("type")
  provider          String  @map("provider")
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @map("refresh_token") @db.Text
  access_token      String? @map("access_token") @db.Text
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String? @map("scope")
  id_token          String? @map("id_token") @db.Text
  session_state     String? @map("session_state")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid()) @map("id")
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime @map("expires")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String   @map("identifier")
  token      String   @unique @map("token")
  expires    DateTime @map("expires")

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model NotificationPreference {
  id                  String   @id @default(cuid()) @map("id")
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyResultPosted  Boolean  @default(true) @map("family_result_posted")
  commentOnResult     Boolean  @default(true) @map("comment_on_result")
  reactionOnResult    Boolean  @default(true) @map("reaction_on_result")
  weeklySummary       Boolean  @default(true) @map("weekly_summary")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

model Family {
  id          String         @id @default(cuid()) @map("id")
  name        String         @map("name")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")
  members     FamilyMember[]
  invites     Invite[]

  @@map("families")
}

// Many-to-many join table: user ↔ family
model FamilyMember {
  id        String    @id @default(cuid()) @map("id")
  familyId  String    @map("family_id")
  userId    String    @map("user_id")
  role      String    @default("member") @map("role") // "admin" | "member"
  joinedAt  DateTime  @default(now()) @map("joined_at")
  deletedAt DateTime? @map("deleted_at")
  family    Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([familyId])
  @@index([userId])
  @@map("family_members")
}

// Invite tokens: UUID v4, single-use, 7-day expiry
model Invite {
  id          String    @id @default(cuid()) @map("id")
  token       String    @unique @map("token")   // UUID v4
  familyId    String    @map("family_id")
  invitedById String    @map("invited_by_id")
  email       String?   @map("email")           // optional — pre-fill signup
  usedAt      DateTime? @map("used_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  family      Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([familyId])
  @@map("invites")
}

model ParkrunLocation {
  id        String          @id @default(cuid()) @map("id")
  name      String          @unique @map("name")
  country   String?         @map("country")
  createdAt DateTime        @default(now()) @map("created_at")
  results   ParkrunResult[]

  @@map("parkrun_locations")
}

model ParkrunResult {
  id              String          @id @default(cuid()) @map("id")
  userId          String          @map("user_id")
  locationId      String          @map("location_id")
  date            DateTime        @map("date") @db.Date
  finishTimeSecs  Int             @map("finish_time_secs") // stored as total seconds
  ageGradedPct    Float?          @map("age_graded_pct")   // populated by Story 4-2
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  location        ParkrunLocation @relation(fields: [locationId], references: [id])
  photos          Photo[]

  @@unique([userId, date])
  @@index([userId])
  @@index([locationId])
  @@index([date])
  @@map("parkrun_results")
}

model Milestone {
  id        String   @id @default(cuid()) @map("id")
  userId    String   @map("user_id")
  type      String   @map("type")      // "run_count" | "personal_best" | "age_grade"
  value     String   @map("value")     // e.g. "10", "50", "60", "pb_time", "pb_ag"
  resultId  String?  @map("result_id") // the result that triggered it
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, value])
  @@index([userId])
  @@map("milestones")
}

model Photo {
  id           String        @id @default(cuid()) @map("id")
  resultId     String        @map("result_id")
  userId       String        @map("user_id")
  displayUrl   String        @map("display_url")   // 800px resized
  thumbnailUrl String        @map("thumbnail_url") // 200px thumbnail
  originalName String?       @map("original_name")
  deletedAt    DateTime?     @map("deleted_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  result       ParkrunResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resultId])
  @@index([userId])
  @@map("photos")
}
